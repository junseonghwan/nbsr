nbsr_dt <- data.table(log_fc=nbsr_log_fc, lb=nbsr_lb, ub=nbsr_ub, pval=nbsr_adj_pvals, gt_log_fc=log_fc$log_fc, method="NBSR")
nbsr_stats <- nbsr_log_fc/nbsr_log_fc_sd
nbsr_pvals <- 2*pnorm(abs(nbsr_stats), lower.tail = FALSE)
nbsr_adj_pvals <- p.adjust(nbsr_pvals, method = "BH")
deseq2_dt <- data.table(log_fc=res2$log2FoldChange, lb=deseq2_lb, ub=deseq2_ub, pval=res2$padj, gt_log_fc=fc$log2_fc, method="DESeq2")
edgeR_dt <- data.table(log_fc=edgeR_results$table$logFC, lb=NA, ub=NA, pval=edgeR_results$table$FDR, gt_log_fc=fc$log2_fc, method="EdgeR")
nbsr_dt <- data.table(log_fc=nbsr_log_fc, lb=nbsr_lb, ub=nbsr_ub, pval=nbsr_adj_pvals, gt_log_fc=log_fc$log_fc, method="NBSR")
nbsr_dt <- data.table(log_fc=nbsr_log_fc, lb=nbsr_lb, ub=nbsr_ub, pval=nbsr_adj_pvals, gt_log_fc=fc$log_fc, method="NBSR")
nbsr_dt
nbsr_dt
