nbsr_log2_fc
nbsr_log2_fc_sd <- log2(exp(nbsr_logRR_sd[1,]))
nbsr_lb <- (nbsr_log2_fc - 1.96*nbsr_log2_fc_sd)
nbsr_ub <- (nbsr_log2_fc + 1.96*nbsr_log2_fc_sd)
nbsr_coverage <- (fc$log2_fc > nbsr_lb) & (fc$log2_fc < nbsr_ub)
mean(nbsr_coverage)
